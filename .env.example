# Contact form email delivery (Resend — https://resend.com)
# Create an API key, verify your sending domain, then set these.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Where enquiries are delivered (use a domain inbox, not Gmail, for credibility)
CONTACT_TO_EMAIL=hello@digitalfuturity.com

# Verified sender on your Resend domain
CONTACT_FROM_EMAIL=Digital Futurity <noreply@digitalfuturity.com>
